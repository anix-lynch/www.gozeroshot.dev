---
import Layout from '../components/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import { projects } from '../data/projects-detailed.js';

// Hand-picked featured — northstar first, then one per lane
const featuredSlugs = ["healthcare-ai-platform-signals", "healthcare-ai-data-engineer", "healthcare-genai-engineer", "pied-piper-legal", "healthcare-forward-deployed-engineer", "healthcare-analytics-fabric"];
const featured = featuredSlugs.map(slug => projects.find(p => p.slug === slug)).filter(Boolean);

const tagsOf = (p) => (p.tags && p.tags.length ? p.tags : [p.lane]);

const laneColors = {
  "GenAI":      { bg: "#eaf3fb", text: "#2a6fa8", border: "rgba(123,179,217,0.4)" },
  "Data Eng":   { bg: "#f0ebff", text: "#5b3fa0", border: "rgba(180,140,220,0.3)" },
  "AI Platform":      { bg: "#edfaf0", text: "#1e6b38", border: "rgba(100,200,130,0.3)" },
  "Automation": { bg: "#fffbe6", text: "#7a5f00", border: "rgba(245,200,66,0.4)" },
  "Cloud":      { bg: "#e6f2f2", text: "#2a7a7a", border: "rgba(90,139,139,0.4)" },
  "Solutions":  { bg: "#fbeee6", text: "#a85a2a", border: "rgba(217,139,111,0.4)" },
};

const laneThumbBg = {
  "GenAI":      "#ddeef8",
  "Data Eng":   "#ece6f8",
  "AI Platform":      "#dff5e5",
  "Automation": "#fdf6d8",
  "Cloud":      "#dceeee",
  "Solutions":  "#f6e4d8",
};

const navLanes = ["GenAI", "Data Eng", "AI Platform", "Automation", "Cloud", "Solutions"];
const laneIcons = { "GenAI": "bot", "Data Eng": "database", "AI Platform": "activity", "Automation": "workflow", "Cloud": "layers", "Solutions": "heart" };
const laneCounts = navLanes.reduce((a, l) => { a[l] = projects.filter(p => tagsOf(p).includes(l)).length; return a; }, {});

const svgPaths = {
  cpu:           `<path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 1-2-2V9m0 0h18"/>`,
  layers:        `<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>`,
  workflow:      `<rect x="3" y="3" width="6" height="6" rx="1"/><rect x="15" y="15" width="6" height="6" rx="1"/><path d="M6 9v3a3 3 0 0 0 3 3h6"/>`,
  database:      `<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19a9 3 0 0 0 18 0V5"/><path d="M3 12a9 3 0 0 0 18 0"/>`,
  search:        `<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>`,
  "bar-chart":   `<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>`,
  "trending-up": `<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>`,
  shield:        `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  activity:      `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
  "file-text":   `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>`,
  "external-link": `<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>`,
  "arrow-right": `<line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>`,
  bot:           `<rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/>`,
  heart:         `<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>`,
  cloud:         `<path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/>`,
};

function icon(name, size = 18) {
  const path = svgPaths[name] || svgPaths['cpu'];
  return `<svg width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">${path}</svg>`;
}
---

<Layout
  title="Anix Lynch — AI Data Engineer & GenAI Architect"
  description="Production AI and data engineering systems — grounded RAG, dbt-on-BigQuery warehouses, and cloud deploys, each traceable to its repo. Built in LA."
  image="/profile-photo.jpg"
>
  <div class="app-shell">
    <Sidebar
      name="Anix Lynch"
      tagline={"AI Data Engineer · GenAI Architect\nLos Angeles, CA"}
      avatar="/profile-photo.jpg"
      about="Most AI projects fail before the model. I build the systems that connect trusted data, meaningful signals, AI workflows, and human adoption — Truth → Context → Signals → Actions → Adoption."
      social={{
        github:    "https://github.com/anix-lynch",
        linkedin:  "https://linkedin.com/in/anixlynch",
        email:     "anix@anixlynch.com",
        bluesky:   "https://bsky.app/profile/anixlynch.bsky.social",
        medium:    "https://medium.com/@anixlynch",
        hashnode:  "https://anixblog.hashnode.dev",
        twitter:   "https://x.com/anixlynch",
        youtube:   "https://youtube.com/@anix_lynch",
        huggingface: "https://huggingface.co/spaces/anixlynch/anixlynch",
        home:      "/"
      }}
    />

    <main class="home-main">

      <!-- Page header -->
      <div class="page-header">
        <div>
          <h1 class="page-title">Portfolio</h1>
          <p class="page-sub">Production AI systems — real evals, real costs, traceable to code.</p>
        </div>
        <a href="/projects" class="btn-browse">
          <Fragment set:html={icon('layers', 15)} />
          All {projects.length} projects
        </a>
      </div>

      <!-- Proof numbers removed: headline metrics must each trace to a repo;
           0.92 Ragas contradicted the genai-engineer repo's own 0.65. Re-add
           only verified numbers if/when wanted. -->


      <!-- Lane filter (jumps to the full filtered grid) -->
      <div class="lane-nav">
        <a href="/projects" class="lane-chip">All <span class="lane-chip-n">{projects.length}</span></a>
        {navLanes.map(lane => (
          <a href={`/projects?lane=${encodeURIComponent(lane)}`} class="lane-chip"
             style={`--c:${laneColors[lane].text};--bg:${laneColors[lane].bg};--bd:${laneColors[lane].border}`}>
            <span class="lane-chip-i" set:html={icon(laneIcons[lane], 13)} />
            {lane} <span class="lane-chip-n">{laneCounts[lane]}</span>
          </a>
        ))}
      </div>

      <!-- Architecture: the L1→L3 bridge story (cohesive with the ALICE career model) -->
      <div class="section-label">How the work connects</div>
      <div class="layer-stack">
        <a class="layer" href="/projects?lane=Data%20Eng" style="--lc:#5b3fa0;--lbg:#f0ebff">
          <span class="layer-tag">L1 · Truth</span>
          <span class="layer-q">What happened?</span>
          <span class="layer-ex">dbt · BigQuery · data quality · governance</span>
          <span class="layer-lane">Data Eng →</span>
        </a>
        <div class="layer-arrow">↓</div>
        <a class="layer" href="/projects?lane=AI%20Platform" style="--lc:#1e6b38;--lbg:#edfaf0">
          <span class="layer-tag">L1.5 · Signal</span>
          <span class="layer-q">What might happen?</span>
          <span class="layer-ex">anomaly · cluster · classify · forecast · rank</span>
          <span class="layer-lane">AI Platform →</span>
        </a>
        <div class="layer-arrow">↓</div>
        <a class="layer" href="/projects?lane=GenAI" style="--lc:#2a6fa8;--lbg:#eaf3fb">
          <span class="layer-tag">L2 · Action</span>
          <span class="layer-q">What should the system do?</span>
          <span class="layer-ex">RAG · agents · tool calling · guardrails · eval</span>
          <span class="layer-lane">GenAI →</span>
        </a>
        <div class="layer-arrow">↓</div>
        <a class="layer" href="/projects?lane=Solutions" style="--lc:#a85a2a;--lbg:#fbeee6">
          <span class="layer-tag">L3 · Influence</span>
          <span class="layer-q">How do humans adopt it?</span>
          <span class="layer-ex">forward-deployed · solutions · exec narratives</span>
          <span class="layer-lane">Solutions →</span>
        </a>
      </div>
      <p class="layer-note">Most engineers own one layer. The leverage is bridging them — trusted data → signals → agents → human adoption.</p>

      <!-- Featured projects -->
      <div class="section-label">Featured Projects</div>
      <div class="project-grid">
        {featured.map(project => {
          const primary = tagsOf(project)[0];
          const lc = laneColors[primary] || laneColors["GenAI"];
          const thumbBg = laneThumbBg[primary] || laneThumbBg["GenAI"];
          return (
            <a
              href={`/projects/${project.slug}`}
              class="project-card"
              data-lane={project.lane}
            >
              {project.gif ? (
                <div class="card-thumb">
                  <img src={project.gif} alt={project.title} loading="lazy" />
                </div>
              ) : (
                <div class="card-thumb card-thumb-placeholder" style={`background:${thumbBg}`}>
                  <span style={`color:${lc.text};opacity:0.5`} set:html={icon(project.icon, 36)} />
                </div>
              )}

              <div class="card-content">
                <div class="card-top">
                  <div class="card-icon-box">
                    <Fragment set:html={icon(project.icon, 20)} />
                  </div>
                  <div class="card-badges">
                    <span class="card-lane-badge"
                      style={`background:${lc.bg};color:${lc.text};border-color:${lc.border}`}>
                      {primary}
                    </span>
                    {project.cloud && (
                      <span class="cloud-badge">☁ {project.cloud}</span>
                    )}
                    {project.live && (
                      <span class="live-badge">
                        <span class="live-dot"></span>
                        Live
                      </span>
                    )}
                  </div>
                </div>

                <div class="card-body">
                  <h2 class="card-title">{project.title}</h2>
                  <p class="card-desc">{project.tagline}</p>
                </div>

                <div class="card-footer">
                  <div class="card-stack-row">
                    {project.stack.slice(0, 3).map((tech: string) => (
                      <span class="mini-pill">{tech}</span>
                    ))}
                    {project.stack.length > 3 && (
                      <span class="mini-pill mini-pill-more">+{project.stack.length - 3}</span>
                    )}
                  </div>
                  {project.stats[0] && (
                    <div class="card-stat">
                      <span class="card-stat-value">{project.stats[0].value}</span>
                      <span class="card-stat-label">{project.stats[0].label}</span>
                    </div>
                  )}
                </div>
              </div>
            </a>
          );
        })}
      </div>

      <!-- View all CTA -->
      <div class="cta-row">
        <a href="/projects" class="btn-view-all">
          Browse all {projects.length} projects
          <Fragment set:html={icon('arrow-right', 15)} />
        </a>
      </div>

      <!-- Monitoring section -->
      <div class="section-label" style="margin-top: 2.5rem;">Production Monitoring</div>
      <div class="monitoring-grid">
        {([
          { title: "Phoenix GenAI Ops",    desc: "Agent traces · eval scores · cost",    url: "/dashboards/phoenix_dashboard.html", iconName: "activity" },
          { title: "Python + dbt DQ",      desc: "24 custom checks · 100% pass rate",     url: "/dashboards/ge_dashboard.html",      iconName: "shield" },
          { title: "dbt Lineage Tracker",  desc: "12 models · 47 tests · 100% coverage", url: "/dashboards/dbt_dashboard.html",     iconName: "trending-up" },
        ] as const).map(m => (
          <a href={m.url} class="monitor-card">
            <span class="monitor-icon" set:html={icon(m.iconName, 18)} />
            <div>
              <div class="monitor-title">{m.title}</div>
              <div class="monitor-desc">{m.desc}</div>
            </div>
            <span class="monitor-arrow" set:html={icon('arrow-right', 14)} />
          </a>
        ))}
      </div>

    </main>
  </div>
</Layout>

<style is:global>
  body { display: block; }
</style>

<style>
  /* ── Shell ─────────────────────────────────────── */
  .app-shell {
    width: 100%;
    display: flex;
    min-height: 100vh;
    background: var(--color-surface-1, #f8fbfd);
  }

  .home-main {
    flex: 1;
    min-width: 0;
    padding: 2rem 1.5rem 4rem;
  }

  /* ── Page header ───────────────────────────────── */
  .page-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .page-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: #0f1923;
    margin: 0 0 0.3rem;
  }

  .page-sub {
    font-size: 14px;
    color: #8aa0b8;
    margin: 0;
  }

  .btn-browse {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 7px 16px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 500;
    background: #fff;
    border: 1px solid #dde8f0;
    color: #4a6080;
    text-decoration: none;
    transition: all 0.15s;
    white-space: nowrap;
  }

  .btn-browse:hover {
    background: #eef4f9;
    border-color: #b8d4ec;
    color: #0f1923;
  }

  /* ── Proof row ─────────────────────────────────── */
  .proof-row {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .proof-pill {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    padding: 6px 14px;
    background: #fff;
    border: 1px solid #dde8f0;
    border-radius: 10px;
    box-shadow: 0 1px 3px rgba(100,140,180,0.07);
  }

  .proof-val {
    font-size: 15px;
    font-weight: 800;
    color: #0f1923;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .proof-lbl {
    font-size: 11px;
    color: #8aa0b8;
    font-weight: 500;
  }

  /* ── Section label ─────────────────────────────── */
  .section-label {
    font-size: 11px;
    font-weight: 700;
    color: #8aa0b8;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.875rem;
  }

  /* ── Project grid ──────────────────────────────── */
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
    margin-bottom: 1.25rem;
  }

  /* ── Card ──────────────────────────────────────── */
  .project-card {
    background: #fff;
    border: 1px solid #dde8f0;
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    box-shadow: 0 1px 3px rgba(100,140,180,0.07);
    transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
  }

  .project-card:hover {
    box-shadow: 0 6px 20px rgba(100,140,180,0.16);
    transform: translateY(-3px);
    border-color: #b8d4ec;
  }

  .card-thumb {
    width: 100%;
    height: 200px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 0.3s ease;
  }

  .project-card:hover .card-thumb img {
    transform: scale(1.03);
  }

  .card-thumb-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-content {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    flex: 1;
  }

  .card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .card-icon-box {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: #eef4f9;
    border: 1px solid #dde8f0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #7bb3d9;
    flex-shrink: 0;
  }

  .card-badges {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .card-lane-badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 9px;
    border-radius: 999px;
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.03em;
    border: 1px solid;
  }

  .cloud-badge {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.04em;
    background: #2b2b28;
    color: #fbf9f4;
  }

  /* Lane filter chips on the homepage → deep-link to /projects?lane= */
  .lane-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 18px 0 26px;
  }
  .lane-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 13px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    color: var(--c, #2a6fa8);
    background: var(--bg, #f3eee3);
    border: 1.5px solid var(--bd, rgba(0,0,0,0.08));
    transition: transform .1s ease, filter .1s ease;
  }
  .lane-chip:hover { transform: translateY(-1px); filter: brightness(0.97); }
  .lane-chip-i { display: inline-flex; }
  .lane-chip-n { opacity: 0.6; font-weight: 700; font-size: 11px; }

  /* L1→L3 layer stack — cohesive with the ALICE career architecture */
  .layer-stack { display: flex; flex-direction: column; align-items: stretch; gap: 4px; margin: 6px 0 10px; }
  .layer {
    display: grid;
    grid-template-columns: 130px 1fr auto;
    align-items: center;
    gap: 14px;
    padding: 12px 16px;
    border-radius: 12px;
    text-decoration: none;
    color: var(--ink, #2b2b28);
    background: var(--lbg, #f3eee3);
    border: 1.5px solid color-mix(in srgb, var(--lc) 30%, transparent);
    transition: transform .1s ease, filter .1s ease;
  }
  .layer:hover { transform: translateX(3px); filter: brightness(0.98); }
  .layer-tag { font-family: var(--mono, monospace); font-weight: 800; font-size: 13px; color: var(--lc); }
  .layer-q { font-weight: 600; font-size: 13.5px; }
  .layer-ex { grid-column: 2; font-size: 12px; color: var(--soft, #6b6760); margin-top: 1px; }
  .layer-lane { font-family: var(--mono, monospace); font-size: 11.5px; font-weight: 700; color: var(--lc); white-space: nowrap; }
  .layer-arrow { text-align: center; color: var(--soft, #6b6760); font-size: 13px; line-height: 1; }
  .layer-note { font-size: 12.5px; color: var(--soft, #6b6760); margin: 0 0 26px; font-style: italic; }
  @media (max-width: 600px) {
    .layer { grid-template-columns: 1fr; gap: 3px; }
    .layer-ex, .layer-lane { grid-column: 1; }
  }

  .live-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 10.5px;
    font-weight: 600;
    background: #edfaf0;
    color: #1e6b38;
    border: 1px solid rgba(100,200,130,0.3);
  }

  .live-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #2ecc71;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }

  .card-body { flex: 1; }

  .card-title {
    font-size: 15px;
    font-weight: 700;
    color: #0f1923;
    margin: 0 0 0.35rem;
    line-height: 1.3;
  }

  .card-desc {
    font-size: 13px;
    color: #4a6080;
    line-height: 1.55;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .card-stack-row {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
    flex: 1;
  }

  .mini-pill {
    display: inline-flex;
    align-items: center;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 10.5px;
    font-weight: 600;
    background: #f0f4f8;
    color: #4a6080;
    border: 1px solid #dde8f0;
    white-space: nowrap;
  }

  .mini-pill-more { background: #eef4f9; color: #8aa0b8; }

  .card-stat {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    flex-shrink: 0;
  }

  .card-stat-value {
    font-size: 14px;
    font-weight: 800;
    color: #0f1923;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .card-stat-label {
    font-size: 10px;
    color: #8aa0b8;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-top: 2px;
  }

  /* ── View all CTA ──────────────────────────────── */
  .cta-row {
    display: flex;
    justify-content: center;
    margin-bottom: 0.5rem;
  }

  .btn-view-all {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 10px 22px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 600;
    background: #7bb3d9;
    color: #fff;
    text-decoration: none;
    border: none;
    transition: background 0.15s, transform 0.15s;
  }

  .btn-view-all:hover {
    background: #5f9bc8;
    transform: translateY(-1px);
