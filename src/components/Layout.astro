---
export interface LayoutProps {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
}

const { 
  title = "Anix Lynch — Proof of Work",
  description = "Production AI systems, data pipelines, and proof-backed builds by Anix Lynch. Real systems, measured behavior, and links to the work.",
  image = "https://www.gozeroshot.dev/profile-photo.jpg",
  url = "https://www.gozeroshot.dev"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, url);
const showHomeReturn = Astro.url.pathname !== "/";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  
  <!-- Primary Meta Tags -->
  <title>{title}</title>
  <meta name="title" content={title} />
  <meta name="description" content={description} />
  <meta name="keywords" content="Anix Lynch, AI Data Engineer, Machine Learning, Data Science, AWS, GCP, Azure, Python, ETL, Data Engineering, AI Architect, Los Angeles, GenAI, LLM Ops, RAG, Vector Databases, Agentic Workflows, Self-Healing AI, AWS Bedrock, Snowflake Cortex, Vertex AI, Great Expectations, dbt, Terraform, Kinesis, Lambda, S3, DynamoDB, BigQuery, Redshift, Cosmos DB, Data Factory, Airflow, LangChain, ChromaDB, Pinecone, Multi-Agent Systems, Hallucination Detection, Data Quality, Streaming ETL, Real-time ML, Production ML Pipelines, AI Monitoring, Phoenix, OpenTelemetry, Ragas, Training-Serving Parity, Point-in-Time Correctness, Drift Detection, Cost Optimization, Serverless AI, Multi-Cloud Architecture" />
  <meta name="author" content="Anix Lynch" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  
  <!-- Canonical URL -->
  <link rel="canonical" href={canonicalURL} />
  
  <!-- Open Graph Tags (Social Sharing) -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={image} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="Anix Lynch" />
  <meta property="og:locale" content="en_US" />
  
  <!-- Twitter Card Tags -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={image} />
  <meta name="twitter:creator" content="@anixlynch" />
  
  <!-- Search Engine / Web Crawlers Meta Tags -->
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <meta name="revisit-after" content="7 days" />
  <meta name="language" content="English" />
  
  <!-- Additional Meta Tags -->
  <meta name="theme-color" content="#8cb0d4" />
  <link rel="icon" type="image/jpeg" href="/profile-photo.jpg" />
  <link rel="apple-touch-icon" href="/profile-photo.jpg" />
  
  <!-- JSON-LD Schema Markup (Structured Data) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Anix Lynch",
    "url": "https://www.gozeroshot.dev",
    "image": "https://www.gozeroshot.dev/profile-photo.jpg",
    "description": "AI Data Engineer and AI Architect specializing in machine learning, data visualization, and deploying scalable solutions across AWS, GCP, and Azure.",
    "jobTitle": "AI Data Engineer | AI Architect",
    "location": {
      "@type": "Place",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Los Angeles",
        "addressRegion": "CA",
        "addressCountry": "US"
      }
    },
    "sameAs": [
      "https://www.linkedin.com/in/anixlynch/",
      "https://github.com/anix-lynch",
      "https://x.com/anixlynch",
      "https://medium.com/@anixlynch",
      "https://huggingface.co/spaces/anixlynch/anixlynch"
    ],
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "anixlynch@gmail.com",
      "contactType": "Personal"
    }
  }
  </script>
  
  <!-- Additional Organization Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "url": "https://www.gozeroshot.dev",
    "name": "Anix Lynch",
    "description": "Production AI systems, proof-backed work, and real deployment evidence",
    "author": {
      "@type": "Person",
      "name": "Anix Lynch"
    }
  }
  </script>
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  {showHomeReturn && (
    <a href="/" class="home-return" aria-label="Back to home">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      <span>Home</span>
    </a>
  )}
  <slot />
  <footer class="site-footer">
    <nav class="site-footer-nav" aria-label="Legal">
      <a href="/terms">Terms</a>
      <span aria-hidden="true">·</span>
      <a href="/privacy">Privacy</a>
    </nav>
  </footer>
</body>
</html>

<style is:global>
  .home-return {
    position: fixed;
    top: 1rem;
    right: 1rem;
    z-index: 50;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.48rem 0.74rem;
    border: 1px solid #d7e4ee;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    color: #304765;
    box-shadow: 0 8px 24px rgba(21, 42, 68, 0.08);
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 650;
    backdrop-filter: blur(10px);
  }

  .home-return:hover {
    background: #eef4f9;
    color: #0f1923;
    border-color: #b8d4ec;
  }

  @media (max-width: 720px) {
    .home-return {
      top: 0.7rem;
      right: 0.7rem;
    }
  }
</style>

<style is:global>
  @import '../styles/global.css';
</style>
