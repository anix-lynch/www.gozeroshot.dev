---
import Layout from '../components/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import { projects } from '../data/projects-detailed.js';

// Hand-picked featured — one per lane, all have GIFs
const featuredSlugs = ["ai-job-intelligence", "mocktailverse-bedrock", "churn-ml-pipeline", "healthcare-analytics-fabric"];
const featured = featuredSlugs.map(slug => projects.find(p => p.slug === slug)).filter(Boolean);

const laneColors = {
  "GenAI":    { bg: "#eaf3fb", text: "#2a6fa8", border: "rgba(123,179,217,0.4)" },
  "n8n":      { bg: "#fffbe6", text: "#7a5f00", border: "rgba(245,200,66,0.4)" },
  "Data Eng": { bg: "#f0ebff", text: "#5b3fa0", border: "rgba(180,140,220,0.3)" },
  "ML":       { bg: "#edfaf0", text: "#1e6b38", border: "rgba(100,200,130,0.3)" },
};

const laneThumbBg = {
  "GenAI":    "#ddeef8",
  "n8n":      "#fdf6d8",
  "Data Eng": "#ece6f8",
  "ML":       "#dff5e5",
};

const svgPaths = {
  cpu:           `<path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 1-2-2V9m0 0h18"/>`,
  layers:        `<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>`,
  workflow:      `<rect x="3" y="3" width="6" height="6" rx="1"/><rect x="15" y="15" width="6" height="6" rx="1"/><path d="M6 9v3a3 3 0 0 0 3 3h6"/>`,
  database:      `<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19a9 3 0 0 0 18 0V5"/><path d="M3 12a9 3 0 0 0 18 0"/>`,
  search:        `<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>`,
  "bar-chart":   `<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>`,
  "trending-up": `<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>`,
  shield:        `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  activity:      `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
  "file-text":   `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>`,
  "external-link": `<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>`,
  "arrow-right": `<line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>`,
};

function icon(name, size = 18) {
  const path = svgPaths[name] || svgPaths['cpu'];
  return `<svg width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">${path}</svg>`;
}
---

<Layout
  title="Anix Lynch — AI Data Engineer & GenAI Architect"
  description="Production AI and data engineering systems. Ragas 0.92 faithfulness, 24 Python + dbt data quality checks, 14-tool MCP orchestration. Built in LA."
  image="/profile-photo.jpg"
>
  <div class="app-shell">
    <Sidebar
      name="Anix Lynch"
      tagline={"AI Data Engineer · GenAI Architect\nLos Angeles, CA"}
      avatar="/profile-photo.jpg"
      about="Self-taught AI engineer. Microsoft Fabric, Power BI (TMDL), dbt, and Python data products. 4 sprint lanes: AI-DE, GenAI/Agent, DevRel, n8n. Ex-VC turned builder."
      social={{
        github:    "https://github.com/anix-lynch",
        linkedin:  "https://linkedin.com/in/anixlynch",
        email:     "anix@anixlynch.com",
        bluesky:   "https://bsky.app/profile/anixlynch.bsky.social",
        medium:    "https://medium.com/@anixlynch",
        hashnode:  "https://anixblog.hashnode.dev",
        twitter:   "https://x.com/anixlynch",
        youtube:   "https://youtube.com/@anix_lynch",
        huggingface: "https://huggingface.co/spaces/anixlynch/anixlynch",
        home:      "/"
      }}
    />

    <main class="home-main">

      <!-- Page header -->
      <div class="page-header">
        <div>
          <h1 class="page-title">Portfolio</h1>
          <p class="page-sub">Production AI systems — real evals, real costs, traceable to code.</p>
        </div>
        <a href="/projects" class="btn-browse">
          <Fragment set:html={icon('layers', 15)} />
          All {projects.length} projects
        </a>
      </div>

      <!-- Proof numbers -->
      <div class="proof-row">
        <div class="proof-pill">
          <span class="proof-val">0.92</span>
          <span class="proof-lbl">Ragas faithfulness</span>
        </div>
        <div class="proof-pill">
          <span class="proof-val">24</span>
          <span class="proof-lbl">Python + dbt DQ checks</span>
        </div>
        <div class="proof-pill">
          <span class="proof-val">14</span>
          <span class="proof-lbl">MCP tools</span>
        </div>
        <div class="proof-pill">
          <span class="proof-val">$1–2</span>
          <span class="proof-lbl">/mo serverless</span>
        </div>
        <div class="proof-pill">
          <span class="proof-val">124</span>
          <span class="proof-lbl">Medium articles</span>
        </div>
      </div>

      <!-- Featured projects -->
      <div class="section-label">Featured Projects</div>
      <div class="project-grid">
        {featured.map(project => {
          const lc = laneColors[project.lane] || laneColors["GenAI"];
          const thumbBg = laneThumbBg[project.lane] || laneThumbBg["GenAI"];
          return (
            <a
              href={`/projects/${project.slug}`}
              class="project-card"
              data-lane={project.lane}
            >
              {project.gif ? (
                <div class="card-thumb">
                  <img src={project.gif} alt={project.title} loading="lazy" />
                </div>
              ) : (
                <div class="card-thumb card-thumb-placeholder" style={`background:${thumbBg}`}>
                  <span style={`color:${lc.text};opacity:0.5`} set:html={icon(project.icon, 36)} />
                </div>
              )}

              <div class="card-content">
                <div class="card-top">
                  <div class="card-icon-box">
                    <Fragment set:html={icon(project.icon, 20)} />
                  </div>
                  <div class="card-badges">
                    <span class="card-lane-badge"
                      style={`background:${lc.bg};color:${lc.text};border-color:${lc.border}`}>
                      {project.lane}
                    </span>
                    {project.live && (
                      <span class="live-badge">
                        <span class="live-dot"></span>
                        Live
                      </span>
                    )}
                  </div>
                </div>

                <div class="card-body">
                  <h2 class="card-title">{project.title}</h2>
                  <p class="card-desc">{project.tagline}</p>
                </div>

                <div class="card-footer">
                  <div class="card-stack-row">
                    {project.stack.slice(0, 3).map((tech: string) => (
                      <span class="mini-pill">{tech}</span>
                    ))}
                    {project.stack.length > 3 && (
                      <span class="mini-pill mini-pill-more">+{project.stack.length - 3}</span>
                    )}
                  </div>
                  {project.stats[0] && (
                    <div class="card-stat">
                      <span class="card-stat-value">{project.stats[0].value}</span>
                      <span class="card-stat-label">{project.stats[0].label}</span>
                    </div>
                  )}
                </div>
              </div>
            </a>
          );
        })}
      </div>

      <!-- View all CTA -->
      <div class="cta-row">
        <a href="/projects" class="btn-view-all">
          Browse all {projects.length} projects
          <Fragment set:html={icon('arrow-right', 15)} />
        </a>
      </div>

      <!-- Monitoring section -->
      <div class="section-label" style="margin-top: 2.5rem;">Production Monitoring</div>
      <div class="monitoring-grid">
        {([
          { title: "Phoenix GenAI Ops",    desc: "Agent traces · eval scores · cost",    url: "/dashboards/phoenix_dashboard.html", iconName: "activity" },
          { title: "Great Expectations",   desc: "47 DQ rules · 100% pass rate",          url: "/dashboards/ge_dashboard.html",      iconName: "shield" },
          { title: "dbt Lineage Tracker",  desc: "12 models · 47 tests · 100% coverage", url: "/dashboards/dbt_dashboard.html",     iconName: "trending-up" },
        ] as const).map(m => (
          <a href={m.url} class="monitor-card">
            <span class="monitor-icon" set:html={icon(m.iconName, 18)} />
            <div>
              <div class="monitor-title">{m.title}</div>
              <div class="monitor-desc">{m.desc}</div>
            </div>
            <span class="monitor-arrow" set:html={icon('arrow-right', 14)} />
          </a>
        ))}
      </div>

    </main>
  </div>
</Layout>

<style is:global>
  body { display: block; }
</style>

<style>
  /* ── Shell ─────────────────────────────────────── */
  .app-shell {
    width: 100%;
    display: flex;
    min-height: 100vh;
    background: var(--color-surface-1, #f8fbfd);
  }

  .home-main {
    flex: 1;
    min-width: 0;
    padding: 2rem 1.5rem 4rem;
  }

  /* ── Page header ───────────────────────────────── */
  .page-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .page-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: #0f1923;
    margin: 0 0 0.3rem;
  }

  .page-sub {
    font-size: 14px;
    color: #8aa0b8;
    margin: 0;
  }

  .btn-browse {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 7px 16px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 500;
    background: #fff;
    border: 1px solid #dde8f0;
    color: #4a6080;
    text-decoration: none;
    transition: all 0.15s;
    white-space: nowrap;
  }

  .btn-browse:hover {
    background: #eef4f9;
    border-color: #b8d4ec;
    color: #0f1923;
  }

  /* ── Proof row ─────────────────────────────────── */
  .proof-row {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .proof-pill {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    padding: 6px 14px;
    background: #fff;
    border: 1px solid #dde8f0;
    border-radius: 10px;
    box-shadow: 0 1px 3px rgba(100,140,180,0.07);
  }

  .proof-val {
    font-size: 15px;
    font-weight: 800;
    color: #0f1923;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .proof-lbl {
    font-size: 11px;
    color: #8aa0b8;
    font-weight: 500;
  }

  /* ── Section label ─────────────────────────────── */
  .section-label {
    font-size: 11px;
    font-weight: 700;
    color: #8aa0b8;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.875rem;
  }

  /* ── Project grid ──────────────────────────────── */
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
    margin-bottom: 1.25rem;
  }

  /* ── Card ──────────────────────────────────────── */
  .project-card {
    background: #fff;
    border: 1px solid #dde8f0;
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    box-shadow: 0 1px 3px rgba(100,140,180,0.07);
    transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
  }

  .project-card:hover {
    box-shadow: 0 6px 20px rgba(100,140,180,0.16);
    transform: translateY(-3px);
    border-color: #b8d4ec;
  }

  .card-thumb {
    width: 100%;
    height: 200px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 0.3s ease;
  }

  .project-card:hover .card-thumb img {
    transform: scale(1.03);
  }

  .card-thumb-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-content {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    flex: 1;
  }

  .card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .card-icon-box {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: #eef4f9;
    border: 1px solid #dde8f0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #7bb3d9;
    flex-shrink: 0;
  }

  .card-badges {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .card-lane-badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 9px;
    border-radius: 999px;
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.03em;
    border: 1px solid;
  }

  .live-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 10.5px;
    font-weight: 600;
    background: #edfaf0;
    color: #1e6b38;
    border: 1px solid rgba(100,200,130,0.3);
  }

  .live-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #2ecc71;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }

  .card-body { flex: 1; }

  .card-title {
    font-size: 15px;
    font-weight: 700;
    color: #0f1923;
    margin: 0 0 0.35rem;
    line-height: 1.3;
  }

  .card-desc {
    font-size: 13px;
    color: #4a6080;
    line-height: 1.55;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .card-stack-row {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
    flex: 1;
  }

  .mini-pill {
    display: inline-flex;
    align-items: center;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 10.5px;
    font-weight: 600;
    background: #f0f4f8;
    color: #4a6080;
    border: 1px solid #dde8f0;
    white-space: nowrap;
  }

  .mini-pill-more { background: #eef4f9; color: #8aa0b8; }

  .card-stat {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    flex-shrink: 0;
  }

  .card-stat-value {
    font-size: 14px;
    font-weight: 800;
    color: #0f1923;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .card-stat-label {
    font-size: 10px;
    color: #8aa0b8;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-top: 2px;
  }

  /* ── View all CTA ──────────────────────────────── */
  .cta-row {
    display: flex;
    justify-content: center;
    margin-bottom: 0.5rem;
  }

  .btn-view-all {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 10px 22px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 600;
    background: #7bb3d9;
    color: #fff;
    text-decoration: none;
    border: none;
    transition: background 0.15s, transform 0.15s;
  }

  .btn-view-all:hover {
    background: #5f9bc8;
    transform: translateY(-1px);
  }

  /* ── Monitoring grid ───────────────────────────── */
  .monitoring-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.75rem;
  }

  .monitor-card {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 14px 16px;
    background: #fff;
    border: 1px solid #dde8f0;
    border-radius: 12px;
    text-decoration: none;
    box-shadow: 0 1px 3px rgba(100,140,180,0.06);
    transition: all 0.15s;
  }

  .monitor-card:hover {
    border-color: #b8d4ec;
    box-shadow: 0 4px 12px rgba(100,140,180,0.12);
    transform: translateY(-2px);
  }

  .monitor-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 9px;
    background: #eef4f9;
    color: #7bb3d9;
    flex-shrink: 0;
  }

  .monitor-title {
    font-size: 13.5px;
    font-weight: 600;
    color: #0f1923;
    line-height: 1.2;
    margin-bottom: 2px;
  }

  .monitor-desc {
    font-size: 11.5px;
    color: #8aa0b8;
    line-height: 1.4;
  }

  .monitor-arrow {
    display: flex;
    align-items: center;
    color: #b8d4ec;
    margin-left: auto;
    flex-shrink: 0;
    transition: color 0.15s, transform 0.15s;
  }

  .monitor-card:hover .monitor-arrow {
    color: #7bb3d9;
    transform: translateX(2px);
  }

  /* ── Responsive ────────────────────────────────── */
  @media (max-width: 1024px) {
    .home-main { padding: 1.5rem; }
  }

  @media (max-width: 768px) {
    .project-grid { grid-template-columns: 1fr; }
    .proof-row { gap: 0.4rem; }
    .proof-pill { padding: 5px 10px; }
  }
</style>
