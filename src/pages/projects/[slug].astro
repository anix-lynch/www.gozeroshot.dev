---
import Layout from '../../components/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { projects } from '../../data/projects-detailed.js';

export async function getStaticPaths() {
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;

// Inline SVG paths (Lucide-style, stroke-width 1.5)
const svgPaths = {
  cpu: `<path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/>`,
  layers: `<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>`,
  workflow: `<rect x="3" y="3" width="6" height="6" rx="1"/><rect x="15" y="15" width="6" height="6" rx="1"/><path d="M6 9v3a3 3 0 0 0 3 3h6"/>`,
  database: `<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19a9 3 0 0 0 18 0V5"/><path d="M3 12a9 3 0 0 0 18 0"/>`,
  search: `<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>`,
  target: `<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>`,
  bot: `<rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/><line x1="8" y1="16" x2="8" y2="16"/><line x1="16" y1="16" x2="16" y2="16"/>`,
  user: `<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>`,
  map: `<polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21 3 6"/><line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/>`,
  zap: `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`,
  "bar-chart": `<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>`,
  "trending-up": `<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>`,
  shield: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  activity: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
  mail: `<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22 6 12 13 2 6"/>`,
  building: `<rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><path d="M9 22V12h6v10"/><path d="M9 7h1"/><path d="M9 12h1"/><path d="M14 7h1"/><path d="M14 12h1"/>`,
  code: `<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>`,
  heart: `<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>`,
  "file-text": `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>`,
  calendar: `<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>`,
  "dollar-sign": `<line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>`,
  "map-pin": `<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>`,
  "arrow-left": `<line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>`,
  "external-link": `<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>`,
  github: `<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>`,
};

function icon(name, size = 20) {
  const path = svgPaths[name] || svgPaths['cpu'];
  return `<svg width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">${path}</svg>`;
}

const laneColors = {
  "GenAI":    { bg: "#eaf3fb", text: "#2a6fa8", border: "rgba(123,179,217,0.4)" },
  "n8n":      { bg: "#fffbe6", text: "#7a5f00", border: "rgba(245,200,66,0.4)" },
  "Data Eng": { bg: "#f0ebff", text: "#5b3fa0", border: "rgba(180,140,220,0.3)" },
  "ML":       { bg: "#edfaf0", text: "#1e6b38", border: "rgba(100,200,130,0.3)" },
};
const lc = laneColors[project.lane] || laneColors["GenAI"];
---

<Layout
  title={`${project.title} — Anix Lynch`}
  description={project.tagline}
>
  <div class="app-shell">
    <Sidebar
      name="Anix Lynch"
      tagline="AI Data Engineer · GenAI Architect\nLos Angeles, CA"
      avatar="/profile-photo.jpg"
      about="Self-taught AI engineer. 4 sprint lanes: AI Data Engineering, GenAI/Agent, DevRel, n8n. Ex-VC background."
      social={{
        github: "https://github.com/anix-lynch",
        linkedin: "https://linkedin.com/in/anixlynch",
        email: "alynch@gozeroshot.dev",
        bluesky: "https://bsky.app/profile/anixlynch.bsky.social",
        medium: "https://medium.com/@anixlynch",
        home: "/"
      }}
    />

    <main class="project-main">

      <!-- Breadcrumb -->
      <nav class="breadcrumb">
        <a href="/" class="breadcrumb-link">
          <Fragment set:html={icon('arrow-left', 14)} />
          All Projects
        </a>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current">{project.title}</span>
      </nav>

      <!-- Hero -->
      <header class="project-hero">
        <div class="hero-top">
          <div class="hero-icon-box">
            <Fragment set:html={icon(project.icon, 24)} />
          </div>
          <div class="hero-meta">
            <div class="hero-badges">
              <span class="lane-badge" style={`background:${lc.bg};color:${lc.text};border-color:${lc.border}`}>
                {project.lane}
              </span>
              <span class={`status-badge status-${project.status.toLowerCase()}`}>
                {project.status}
              </span>
            </div>
            <h1 class="hero-title">{project.title}</h1>
            <p class="hero-tagline">{project.tagline}</p>
          </div>
          <div class="hero-actions">
            <a href={project.github} target="_blank" rel="noopener" class="btn btn-ghost">
              <Fragment set:html={icon('github', 15)} />
              View Code
            </a>
            {project.live && (
              <a href={project.live} target="_blank" rel="noopener" class="btn btn-primary">
                <Fragment set:html={icon('external-link', 15)} />
                Live Demo
              </a>
            )}
          </div>
        </div>
      </header>

      <!-- Stats Row -->
      <div class="stats-row">
        {project.stats.map(stat => (
          <div class="stat-card">
            <div class="stat-value">{stat.value}</div>
            <div class="stat-label">{stat.label}</div>
          </div>
        ))}
      </div>

      <!-- Description + Highlight -->
      <section class="description-block">
        <p class="description-text">{project.description}</p>
        {project.highlight && (
          <blockquote class="highlight-quote">
            <Fragment set:html={icon('zap', 16)} />
            <span>{project.highlight}</span>
          </blockquote>
        )}
      </section>

      <!-- Stack Pills -->
      <section class="stack-section">
        <h2 class="section-label">Tech Stack</h2>
        <div class="stack-pills">
          {project.stack.map(tech => (
            <span class="stack-pill">{tech}</span>
          ))}
        </div>
      </section>

      <!-- Feature Grid -->
      <section class="features-section">
        <h2 class="section-label">Features</h2>
        <div class="feature-grid">
          {project.features.map(feature => (
            <div class="feature-card">
              <div class="feature-icon-box">
                <Fragment set:html={icon(feature.icon, 18)} />
              </div>
              <div class="feature-body">
                <h3 class="feature-title">{feature.title}</h3>
                <p class="feature-desc">{feature.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Architecture -->
      <section class="arch-section">
        <h2 class="section-label">How It Works</h2>
        <div class="arch-flow">
          {project.architecture.map((step, i) => (
            <div class="arch-step">
              <div class="arch-number">{step.step}</div>
              <div class="arch-content">
                <div class="arch-label">{step.label}</div>
                <div class="arch-desc">{step.desc}</div>
              </div>
              {i < project.architecture.length - 1 && (
                <div class="arch-arrow">→</div>
              )}
            </div>
          ))}
        </div>
      </section>

      <!-- Footer meta row -->
      <footer class="project-footer">
        <div class="footer-meta">
          <span class="cost-badge">
            <Fragment set:html={icon('dollar-sign', 13)} />
            {project.cost}
          </span>
          {project.phase && (
            <span class="phase-note">{project.phase}</span>
          )}
        </div>
        <div class="footer-actions">
          <a href={project.github} target="_blank" rel="noopener" class="btn btn-primary btn-lg">
            <Fragment set:html={icon('github', 16)} />
            View on GitHub
          </a>
          {project.live && (
            <a href={project.live} target="_blank" rel="noopener" class="btn btn-ghost btn-lg">
              <Fragment set:html={icon('external-link', 16)} />
              Open Live Demo
            </a>
          )}
          <a href="/" class="btn btn-ghost btn-lg">
            <Fragment set:html={icon('arrow-left', 16)} />
            All Projects
          </a>
        </div>
      </footer>

    </main>
  </div>
</Layout>

<style>
  /* ── Shell ────────────────────────────────────── */
  .app-shell {
    display: flex;
    min-height: 100vh;
    background: #f8fbfd;
  }

  /* ── Main ─────────────────────────────────────── */
  .project-main {
    flex: 1;
    min-width: 0;
    padding: 2rem 2.5rem 4rem;
    max-width: 860px;
  }

  /* ── Breadcrumb ───────────────────────────────── */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 13px;
    color: #8aa0b8;
    margin-bottom: 1.75rem;
  }

  .breadcrumb-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: #7bb3d9;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.15s;
  }

  .breadcrumb-link:hover { color: #5f9bc8; }
  .breadcrumb-sep { color: #c8d8e8; }
  .breadcrumb-current { color: #4a6080; font-weight: 500; }

  /* ── Hero ─────────────────────────────────────── */
  .project-hero {
    margin-bottom: 1.5rem;
  }

  .hero-top {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .hero-icon-box {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: #eef4f9;
    border: 1px solid #dde8f0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #7bb3d9;
    flex-shrink: 0;
    margin-top: 4px;
  }

  .hero-meta {
    flex: 1;
    min-width: 0;
  }

  .hero-badges {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }

  .lane-badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.02em;
    border: 1px solid;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 9px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
  }

  .status-production  { background: #edfaf0; color: #1e6b38; border: 1px solid rgba(100,200,130,0.3); }
  .status-experimental { background: #fff8e6; color: #7a5f00; border: 1px solid rgba(245,200,66,0.3); }
  .status-research    { background: #f0ebff; color: #5b3fa0; border: 1px solid rgba(180,140,220,0.3); }

  .hero-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: #0f1923;
    line-height: 1.2;
    margin: 0 0 0.4rem;
  }

  .hero-tagline {
    font-size: 15px;
    color: #4a6080;
    line-height: 1.5;
    margin: 0;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  /* ── Buttons ──────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 7px 16px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: all 0.15s ease;
    white-space: nowrap;
    line-height: 1;
  }

  .btn-primary {
    background: #7bb3d9;
    color: #fff;
  }
  .btn-primary:hover { background: #5f9bc8; color: #fff; }

  .btn-ghost {
    background: #eef4f9;
    color: #4a6080;
    border: 1px solid #dde8f0;
  }
  .btn-ghost:hover { background: #e2ecf4; color: #0f1923; }

  .btn-lg {
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 600;
    border-radius: 12px;
  }

  /* ── Stats Row ────────────────────────────────── */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .stat-card {
    background: #fff;
    border: 1px solid #dde8f0;
    border-radius: 12px;
    padding: 1rem;
    text-align: center;
    box-shadow: 0 1px 3px rgba(100,140,180,0.08);
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: #0f1923;
    line-height: 1;
    margin-bottom: 0.3rem;
    font-variant-numeric: tabular-nums;
  }

  .stat-label {
    font-size: 11px;
    font-weight: 600;
    color: #8aa0b8;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* highlight the first stat with yellow accent */
  .stats-row .stat-card:first-child {
    background: rgba(245, 230, 66, 0.10);
    border-color: rgba(245, 200, 66, 0.35);
  }

  .stats-row .stat-card:first-child .stat-value {
    color: #6b5900;
  }

  /* ── Description ──────────────────────────────── */
  .description-block {
    margin-bottom: 2rem;
  }

  .description-text {
    font-size: 15px;
    color: #4a6080;
    line-height: 1.75;
    margin: 0 0 1.25rem;
  }

  .highlight-quote {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    background: #eaf3fb;
    border-left: 3px solid #7bb3d9;
    border-radius: 0 10px 10px 0;
    padding: 0.875rem 1.25rem;
    margin: 0;
    color: #2a6fa8;
    font-size: 14px;
    font-style: normal;
    font-weight: 500;
    line-height: 1.6;
  }

  .highlight-quote svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: #7bb3d9;
  }

  /* ── Section label ────────────────────────────── */
  .section-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #8aa0b8;
    margin: 0 0 0.875rem;
  }

  /* ── Stack Pills ──────────────────────────────── */
  .stack-section {
    margin-bottom: 2rem;
  }

  .stack-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .stack-pill {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    background: rgba(123, 179, 217, 0.12);
    color: #2a6fa8;
    border: 1px solid rgba(123, 179, 217, 0.28);
  }

  /* ── Feature Grid ─────────────────────────────── */
  .features-section {
    margin-bottom: 2rem;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.875rem;
  }

  .feature-card {
    background: #fff;
    border: 1px solid #dde8f0;
    border-radius: 12px;
    padding: 1.25rem;
    display: flex;
    gap: 1rem;
    box-shadow: 0 1px 2px rgba(100,140,180,0.06);
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .feature-card:hover {
    box-shadow: 0 4px 14px rgba(100,140,180,0.14);
    transform: translateY(-2px);
  }

  .feature-icon-box {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: #eef4f9;
    border: 1px solid #dde8f0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #7bb3d9;
    flex-shrink: 0;
  }

  .feature-body { flex: 1; min-width: 0; }

  .feature-title {
    font-size: 13.5px;
    font-weight: 600;
    color: #0f1923;
    margin: 0 0 0.3rem;
    line-height: 1.3;
  }

  .feature-desc {
    font-size: 13px;
    color: #4a6080;
    line-height: 1.55;
    margin: 0;
  }

  /* ── Architecture ─────────────────────────────── */
  .arch-section {
    margin-bottom: 2rem;
  }

  .arch-flow {
    display: flex;
    align-items: stretch;
    gap: 0;
    flex-wrap: wrap;
    background: #fff;
    border: 1px solid #dde8f0;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 1px 3px rgba(100,140,180,0.07);
  }

  .arch-step {
    flex: 1;
    min-width: 140px;
    display: flex;
    align-items: stretch;
    position: relative;
  }

  .arch-number {
    writing-mode: initial;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    background: #eef4f9;
    font-size: 11px;
    font-weight: 800;
    color: #8aa0b8;
    letter-spacing: 0.05em;
    border-right: 1px solid #dde8f0;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  .arch-content {
    padding: 1.1rem 1rem;
    flex: 1;
  }

  .arch-label {
    font-size: 12px;
    font-weight: 700;
    color: #0f1923;
    margin-bottom: 0.3rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .arch-desc {
    font-size: 12px;
    color: #4a6080;
    line-height: 1.5;
  }

  .arch-arrow {
    display: flex;
    align-items: center;
    padding: 0 0.25rem;
    color: #b0c8e0;
    font-size: 18px;
    font-weight: 300;
    flex-shrink: 0;
  }

  /* ── Footer ───────────────────────────────────── */
  .project-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 2rem;
    border-top: 1px solid #dde8f0;
    margin-top: 1rem;
  }

  .footer-meta {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .cost-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 12px;
    color: #4a6080;
  }

  .phase-note {
    font-size: 12px;
    color: #8aa0b8;
    font-style: italic;
  }

  .footer-actions {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  /* ── Responsive ───────────────────────────────── */
  @media (max-width: 1100px) {
    .project-main { padding: 1.5rem; }
  }

  @media (max-width: 900px) {
    .hero-top { flex-wrap: wrap; }
    .hero-actions { flex-direction: row; width: 100%; }
    .stats-row { grid-template-columns: repeat(2, 1fr); }
    .feature-grid { grid-template-columns: 1fr; }
    .arch-flow { flex-direction: column; }
    .arch-arrow { display: none; }
    .arch-step { min-width: unset; border-bottom: 1px solid #dde8f0; }
    .arch-step:last-child { border-bottom: none; }
  }

  @media (max-width: 640px) {
    .project-main { padding: 1rem; }
    .hero-title { font-size: 1.4rem; }
    .stats-row { grid-template-columns: repeat(2, 1fr); gap: 0.5rem; }
    .project-footer { flex-direction: column; align-items: flex-start; }
    .footer-actions { width: 100%; }
